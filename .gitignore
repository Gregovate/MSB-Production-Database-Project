@'
# === Generated artifacts we do not track ===
*.csv
*.html
*.json
*.log

# === SQLite + sidecars ===
*.db
*.sqlite
*.sqlite3
*.db-wal
*.db-shm

# === Office files you chose to ignore ===
*.xlsx

# === Whole working dirs that are data, not code ===
/database/**
/Spreadsheet/**
/Database Previews/**
/UserPreviewStaging/**
/docs/output/**
/docs/Work_Hour_Record/**
/tmp/**
/.venv/**

# Keep placeholders if needed
!database/.gitkeep
!Spreadsheet/.gitkeep
!database/merger/.gitkeep*

# --- PyInstaller build artifacts ---
build/
dist/
build_artifacts/
*.spec

# --- Python cache and temp files ---
__pycache__/
*.pyc
*.pyo
*.pyd

# --- Local / system files ---
.DS_Store
Thumbs.db
'@ | Out-File -Encoding utf8 .gitignore
.venv/
