# === Generated artifacts we do not track ===

*.csv
*.html
*.json
*.log

# === Generated SQLite outputs ===

lor_output*.db
lor_output*.db-wal
lor_output*.db-shm

# Optional SQLite scratch files

*.sqlite
*.sqlite3
*.sqlite-wal
*.sqlite-shm
*.sqlite3-wal
*.sqlite3-shm

# === Office / export artifacts ===

*.xlsx

# === Build artifacts ===

build/
dist/
build_artifacts/
*.spec

# === Python cache / temp ===

__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/

# === Virtual environments ===

.venv/
venv/
env/

# === IDE / editor ===

.vscode/
.idea/

# === Environment / secrets ===

.env
.env.*
*.pem
*.key

# === Local OS files ===

.DS_Store
Thumbs.db

# === Backup / archive files ===

*.bak
*.zip
*.7z

# =========================================================
# PROJECT WORKING DATA (not source code)
# =========================================================

/database/**
/Spreadsheet/**
/Database Previews/**
/UserPreviewStaging/**
/tmp/**
/reports/**
/exports/**

# Generated docs / exports

/docs/output/**
/docs/Work_Hour_Record/**

# =========================================================
# KEEP PLACEHOLDERS
# =========================================================

!database/.gitkeep
!Spreadsheet/.gitkeep
!database/merger/.gitkeep*

# =========================================================
# OPTIONAL: TRACK SMALL REFERENCE DBS
# =========================================================

