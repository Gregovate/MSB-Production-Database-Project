Row: ${row}
Priority: ${priority || ""}
Type: ${taskType || ""}
Stage: ${stage || ""}
Task: ${task || ""}

Notes:
${notes || "(none)"}

Assigned To: ${assignedTo || "(unassigned)"}
Added By: ${addedBy || "(unknown)"}
Date Added: ${dateAdded || ""}

