// Wrapper: send ONLY Priority 1 tasks
function sendNewTaskEmails_P1() {
  sendNewTaskEmailsCore_(true);
}

// Wrapper: send ALL priorities
function sendNewTaskEmails_All() {
  sendNewTaskEmailsCore_(false);
}

// Core grouped sender: one email per person, with optional P1-only filter
function sendNewTaskEmailsCore_(onlyP1) {
  const ss    = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName(TODO_SHEET_NAME);
  if (!sheet) return;

  const lastCol = sheet.getLastColumn();
  let lastRow   = sheet.getLastRow();
  if (lastRow <= HEADER_ROW) return;

  // Find last real data row
  const allData = sheet.getRange(5, 1, lastRow - 4, lastCol).getValues();
  let lastDataRow = HEADER_ROW;

  for (let i = allData.length - 1; i >= 0; i--) {
    const rowVals = allData[i];
    if (rowVals.join("") !== "") {
      lastDataRow = 5 + i;
      break;
    }
  }
  if (lastDataRow < 5) return;

  const sheetUrl     = ss.getUrl();
  const nicknameMap  = getNicknameEmailMap_(); // Nickname -> Email
  const emailTasks   = {};                     // email -> array of task objects
  const rowsWithMail = new Set();

  for (let row = 5; row <= lastDataRow; row++) {
    const assignedRaw = sheet.getRange(row, 7).getValue();              // G - Assigned To (nicknames)
    const emailSent   = sheet.getRange(row, COL_EMAIL_SENT).getValue(); // L - Email Sent
    const priority    = sheet.getRange(row, 2).getValue();              // B - Priority

    // Only new, unsent tasks with an assignee
    if (!assignedRaw || emailSent) continue;

    // If we're in P1-only mode, skip anything that isn't priority 1
    if (onlyP1) {
      const p = (priority !== null && priority !== undefined) ? priority.toString().trim() : "";
      if (p !== "1") continue;
    }

    // Parse nicknames and map to unique emails
    const nicknames = assignedRaw.toString().split(",");
    const rowEmails = new Set();

    nicknames.forEach(p => {
      const nick = p.trim();
      if (!nick) return;

      // Allow direct emails as well
      if (nick.indexOf("@") !== -1) {
        rowEmails.add(nick);
        return;
      }

      const email = nicknameMap[nick];
      if (email) {
        rowEmails.add(email);
      } else {
        Logger.log(`No email found for nickname: ${nick} (row ${row})`);
      }
    });

    if (rowEmails.size === 0) {
      // No valid addresses → don't mark as sent
      continue;
    }

    // Collect task details once
    const taskType   = sheet.getRange(row, 3).getValue();  // C
    const stage      = sheet.getRange(row, 4).getValue();  // D
    const task       = sheet.getRange(row, 5).getValue();  // E
    const notes      = sheet.getRange(row, 6).getValue();  // F
    const addedBy    = sheet.getRange(row, COL_ADDED_BY).getValue();
    const dateAdded  = sheet.getRange(row, COL_DATE_ADDED).getValue();

    const taskInfo = {
      row,
      assignedRaw,
      priority,
      taskType,
      stage,
      task,
      notes,
      addedBy,
      dateAdded
    };

    rowsWithMail.add(row);

    // Attach this task to every email on the row
    rowEmails.forEach(email => {
      if (!emailTasks[email]) emailTasks[email] = [];
      emailTasks[email].push(taskInfo);
    });
  }

  // Send one email per person
  let sentEmails = 0;
  for (const email in emailTasks) {
    const tasks = emailTasks[email];
    if (!tasks || !tasks.length) continue;

    const subject = `MSB Tasks: ${tasks.length} new task(s) assigned${onlyP1 ? " [Priority 1]" : ""}`;

    let body = `Hello,\n\n`;
    body += `You have been assigned the following new task(s) in the MSB build list`;
    if (onlyP1) body += ` (Priority 1 only)`;
    body += `:\n\n`;

    tasks.forEach((t, idx) => {
      body += `${idx + 1}. Row ${t.row} | Stage: ${t.stage || ""} | Priority: ${t.priority || ""}\n`;
      body += `   Type: ${t.taskType || ""}\n`;
      body += `   Task: ${t.task || ""}\n`;
      body += `   Notes:\n      ${t.notes || "(none)"}\n\n`;
    });

    body += `IMPORTANT:\n`;
    body += `When you complete a task, please remember to check the "Done" box in the task list.\n`;
    body += `This automatically records the completion date and moves the item to the Completed list.\n\n`;
    body += `You can view the task list here:\n${sheetUrl}\n\n`;
    body += `-- MSB Task Tracker\n`;

    MailApp.sendEmail({
      to: email,
      subject,
      body
    });

    sentEmails++;
  }

  // Mark all rows that were included in at least one email as "sent"
  const timestamp = new Date();
  rowsWithMail.forEach(row => {
    sheet.getRange(row, COL_EMAIL_SENT).setValue(timestamp);
  });

  Logger.log(`Sent ${sentEmails} grouped email(s), mode = ${onlyP1 ? "P1 only" : "ALL"}.`);
}

