// Wrapper: dry run for P1-only
function dryRunSendTasks_P1() {
  dryRunSendTasksCore_(true);
}

// Wrapper: dry run for all priorities
function dryRunSendTasks_All() {
  dryRunSendTasksCore_(false);
}

function dryRunSendTasksCore_(onlyP1) {
  const ss    = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName(TODO_SHEET_NAME);
  if (!sheet) return;

  const lastCol = sheet.getLastColumn();
  let lastRow   = sheet.getLastRow();
  if (lastRow <= HEADER_ROW) {
    SpreadsheetApp.getUi().alert("No data rows found.");
    return;
  }

  const allData = sheet.getRange(5, 1, lastRow - 4, lastCol).getValues();
  let lastDataRow = HEADER_ROW;

  for (let i = allData.length - 1; i >= 0; i--) {
    const rowVals = allData[i];
    if (rowVals.join("") !== "") {
      lastDataRow = 5 + i;
      break;
    }
  }
  if (lastDataRow < 5) {
    SpreadsheetApp.getUi().alert("No data rows found.");
    return;
  }

  const sheetUrl    = ss.getUrl();
  const nicknameMap = getNicknameEmailMap_();
  const emailTasks  = {};

  for (let row = 5; row <= lastDataRow; row++) {
    const assignedRaw = sheet.getRange(row, 7).getValue();              // G
    const emailSent   = sheet.getRange(row, COL_EMAIL_SENT).getValue(); // L
    const priority    = sheet.getRange(row, 2).getValue();              // B

    // Only NEW unsent tasks
    if (!assignedRaw || emailSent) continue;

    if (onlyP1) {
      const p = (priority !== null && priority !== undefined) ? priority.toString().trim() : "";
      if (p !== "1") continue;
    }

    const nicknames = assignedRaw.toString().split(",");
    const rowEmails = new Set();

    nicknames.forEach(p => {
      const nick = p.trim();
      if (!nick) return;

      if (nick.indexOf("@") !== -1) {
        rowEmails.add(nick);
        return;
      }

      const email = nicknameMap[nick];
      if (email) {
        rowEmails.add(email);
      } else {
        Logger.log(`No email found for nickname: ${nick} (row ${row})`);
      }
    });

    if (rowEmails.size === 0) continue;

    const taskType   = sheet.getRange(row, 3).getValue();
    const stage      = sheet.getRange(row, 4).getValue();
    const task       = sheet.getRange(row, 5).getValue();
    const notes      = sheet.getRange(row, 6).getValue();
    const addedBy    = sheet.getRange(row, COL_ADDED_BY).getValue();
    const dateAdded  = sheet.getRange(row, COL_DATE_ADDED).getValue();

    const taskInfo = {
      row,
      assignedRaw,
      priority,
      taskType,
      stage,
      task,
      notes,
      addedBy,
      dateAdded
    };

    rowEmails.forEach(email => {
      if (!emailTasks[email]) emailTasks[email] = [];
      emailTasks[email].push(taskInfo);
    });
  }

  const emails = Object.keys(emailTasks);
  let preview = "";

  if (!emails.length) {
    preview = "No new unsent tasks would generate emails in this mode.";
  } else {
    emails.forEach(email => {
      const tasks = emailTasks[email];
      preview += "========================================\n";
      preview += `TO: ${email}\n`;
      preview += `Subject: MSB Tasks: ${tasks.length} new task(s) assigned`;
      if (onlyP1) preview += " [Priority 1]";
      preview += `\n\n`;

      tasks.forEach((t, idx) => {
        preview += `${idx + 1}. Row ${t.row} | Stage: ${t.stage || ""} | Priority: ${t.priority || ""}\n`;
        preview += `   Type: ${t.taskType || ""}\n`;
        preview += `   Task: ${t.task || ""}\n`;
        preview += `   Notes:\n      ${t.notes || "(none)"}\n\n`;
      });

      preview += `IMPORTANT:\n`;
      preview += `When you complete a task, please remember to check the "Done" box in the task list.\n`;
      preview += `This automatically records the completion date and moves the item to the Completed list.\n\n`;
      preview += `Sheet Link: ${sheetUrl}\n\n`;
    });
  }

  SpreadsheetApp.getUi().alert(preview);
}

// ---------------------------
// Return array of manager emails from `user master` (Manager column F = TRUE)
// ---------------------------
function getManagerEmails_() {
  const ss    = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName("user master");
  if (!sheet) return [];

  const lastRow = sheet.getLastRow();
  if (lastRow < 2) return [];

  // Columns: A..F, Manager flag is F (6), Email is E (5)
  const values = sheet.getRange(2, 1, lastRow - 1, 6).getValues();
  const emails = [];

  values.forEach(row => {
    const email   = row[4]; // E
    const manager = row[5]; // F
    if (email && manager === true) {
      emails.push(email.toString().trim());
    }
  });

  return emails;
}

// ---------------------------
// Map an email to a Nickname from `user master`, or fall back to local-part
// ---------------------------
function getUsernameFromEmail_(email) {
  if (!email) return "";

  const ss    = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName("user master");
  if (!sheet) {
    // Fallback: local-part only
    return email.split("@")[0];
  }

  const lastRow = sheet.getLastRow();
  if (lastRow < 2) {
    return email.split("@")[0];
  }

  // user master row layout:
  // A First Name
  // B Nickname
  // C Last Name
  // D Username
  // E Email
  // (row array = [A,B,C,D,E])
  const values = sheet.getRange(2, 1, lastRow - 1, 5).getValues();

  for (let i = 0; i < values.length; i++) {
    const row = values[i];

    const nickname  = row[1];  // Column B
    const rowEmail  = row[4];  // Column E

    if (
      rowEmail &&
      rowEmail.toString().trim().toLowerCase() ===
      email.toString().trim().toLowerCase()
    ) {
      if (nickname) return nickname.toString().trim();
      break;
    }
  }

  // If not found, fallback to local-part
  return email.split("@")[0];
}



