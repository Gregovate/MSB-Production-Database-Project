const TODO_SHEET_NAME      = "To do";
const COMPLETED_SHEET_NAME = "Completed";

// Column indexes (1-based)
const COL_DONE         = 1;  // A - Done
const COL_DATE_DONE    = 10; // J - Date Complete
const COL_DATE_ADDED   = 8;  // H - Date Added
const COL_ADDED_BY     = 9;  // I - Added By
const COL_COMPLETED_BY = 11; // K - Completed By
const COL_EMAIL_SENT   = 12;  // L - Email Sent

const HEADER_ROW = 4;         // headers in row 4, data starts at row 5
const ORG_DOMAIN = "sheboyganlights.org";

// ---------------------------
