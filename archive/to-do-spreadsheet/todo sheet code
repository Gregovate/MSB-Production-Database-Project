// ---------------------------
// Simple onEdit trigger
// ---------------------------
function onEdit(e) {
  const sheet = e.range.getSheet();
  if (sheet.getName() !== TASK_SHEET_NAME) return;

  const col = e.range.getColumn();

  if (col === COL_PRIORITY) {
    // Keep whatever logic you already had for priority,
    // but DO NOT sort here.
    handlePriorityEdit_(e);
    return;
  }

  // other handlers stay as-is...
}



// ---------------------------
// Build a lookup: { "Adam" : "abiebel@sheboyganlights.org", ... }
// ---------------------------
function getNicknameEmailMap_() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName("user master");
  if (!sheet) return {};

  // Nickname = col B, Email = col E, starting at row 2
  const lastRow = sheet.getLastRow();
  if (lastRow < 2) return {};

  const values = sheet.getRange(2, 2, lastRow - 1, 4).getValues();
  // values[i] = [B, C, D, E] => [Nickname, LastName, Username, Email]

  const map = {};

  values.forEach(row => {
    const nickname = row[0];        // column B
    const email    = row[3];        // column E
    if (nickname && email) {
      map[nickname.toString().trim()] = email.toString().trim();
    }
  });

  return map;
}

// ---------------------------
// Handle Done checkbox logic
// ---------------------------
function handleDoneEdit_(sheet, row) {
  const doneVal = sheet.getRange(row, COL_DONE).getValue();          // A - Done
  const dateCell = sheet.getRange(row, COL_DATE_DONE);               // J - Date Complete
  const completedByCell = sheet.getRange(row, COL_COMPLETED_BY);     // K - Completed By

  const wasDateSet = !!dateCell.getValue();

  if (doneVal) {
    // Mark completion date if not already set
    if (!wasDateSet) {
      dateCell.setValue(new Date());
    }

    // Set Completed By to nickname (from user master)
    const email = Session.getActiveUser().getEmail();
    if (email) {
      const nickname = getUsernameFromEmail_(email);  // returns Nickname from column B
      completedByCell.setValue(nickname);
    }

    // Only notify managers the FIRST time this gets completed
    if (!wasDateSet) {
      sendManagerTaskCompletedNotification_(sheet, row);
    }

    // Move row to Completed sheet
    moveRowToCompleted_(sheet, row);

  } else {
    // If they uncheck it, clear completion info on the To do sheet row
    dateCell.clearContent();
    completedByCell.clearContent();
  }
}


// ---------------------------
// Move row from To do → Completed
// ---------------------------
function moveRowToCompleted_(sourceSheet, rowIndex) {
  const ss = sourceSheet.getParent();
  let targetSheet = ss.getSheetByName(COMPLETED_SHEET_NAME);

  // Create Completed sheet if it doesn't exist, copy headers
  if (!targetSheet) {
    targetSheet = ss.insertSheet(COMPLETED_SHEET_NAME);
    const headerRange = sourceSheet.getRange(HEADER_ROW, 1, 1, sourceSheet.getLastColumn());
    headerRange.copyTo(targetSheet.getRange(1, 1), { contentsOnly: false });
  }

  const lastCol   = sourceSheet.getLastColumn();
  const rowValues = sourceSheet.getRange(rowIndex, 1, 1, lastCol).getValues();

  const targetLastRow = targetSheet.getLastRow();
  const destRow = targetLastRow >= 1 ? targetLastRow + 1 : 1;
  targetSheet.getRange(destRow, 1, 1, lastCol).setValues(rowValues);

  // Delete the original row
  sourceSheet.deleteRow(rowIndex);
}

// ---------------------------
// Add new task row at bottom
// ---------------------------
function addTaskRow() {
  const ss    = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName(TODO_SHEET_NAME);
  if (!sheet) return;

  const lastRow = sheet.getLastRow();
  const lastCol = sheet.getLastColumn();

  // Find last non-empty data row (bottom-up, rows 5..lastRow)
  let dataLastRow = HEADER_ROW; // 4
  if (lastRow > HEADER_ROW) {
    const dataRange = sheet.getRange(HEADER_ROW + 1, 1, lastRow - HEADER_ROW, lastCol);
    const values = dataRange.getValues();

    for (let i = values.length - 1; i >= 0; i--) {
      const rowVals = values[i];
      if (rowVals.join("") !== "") {
        dataLastRow = HEADER_ROW + 1 + i;
        break;
      }
    }
  }

  // If no data yet, use row 5 as base
  if (dataLastRow < HEADER_ROW + 1) {
    dataLastRow = HEADER_ROW + 1;
  }

  // Insert a new row after the last data row
  const newRowIndex = dataLastRow + 1;
  sheet.insertRowAfter(dataLastRow);

  // Use first data row (row 5) as the template for formatting & validation
  const templateRow = HEADER_ROW + 1; // row 5
  const src = sheet.getRange(templateRow, 1, 1, lastCol);
  const dst = sheet.getRange(newRowIndex, 1, 1, lastCol);

  // Copy formatting & data validation only
  src.copyTo(dst, { formatOnly: true });

  // Clear any copied values but keep formatting/validation
  dst.clearContent();

  // ---- Explicitly create the Done checkbox in column A ----
  const doneCell = sheet.getRange(newRowIndex, COL_DONE);
  doneCell.clearDataValidations();
  doneCell.insertCheckboxes();   // makes it a proper checkbox
  doneCell.setValue(false);      // start unchecked

  // Set Date Added (H)
  sheet.getRange(newRowIndex, COL_DATE_ADDED).setValue(new Date());

  // Set Added By to username (not full email) (I)
  const email = Session.getActiveUser().getEmail();
  if (email) {
    const username = getUsernameFromEmail_(email);
    sheet.getRange(newRowIndex, COL_ADDED_BY).setValue(username);
  }


  // Focus on the new row, Priority column (B = 2, but we use 3 because you wanted Priority? NO – Priority is B)
  sheet.setActiveRange(sheet.getRange(newRowIndex, 2));
}

// ---------------------------
// Sort Tasks by priority then Area
// ---------------------------
function sortTasks() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName(TODO_SHEET_NAME);
  if (!sheet) return;

  const lastCol = sheet.getLastColumn();

  // Find last real data row (not just formatting)
  let lastDataRow = sheet.getLastRow();
  if (lastDataRow <= HEADER_ROW) return;

  const allData = sheet.getRange(5, 1, lastDataRow - 4, lastCol).getValues();

  // Walk bottom-up to find the last non-empty row
  for (let i = allData.length - 1; i >= 0; i--) {
    const row = allData[i];
    if (row.join("") !== "") {
      lastDataRow = 5 + i;
      break;
    }
  }

  if (lastDataRow < 5) return;

  const range = sheet.getRange(5, 1, lastDataRow - 4, lastCol);

  range.sort([
    { column: 2, ascending: true },  // Priority (B)
    { column: 4, ascending: true }   // Stage (D)
  ]);
}

// ---------------------------
// Convert Assigned To (e.g. "Adam, Greg") into email list via nickname → email mapping
// ---------------------------

function getEmailsFromAssigned_(raw) {
  if (!raw) return [];

  const nicknameMap = getNicknameEmailMap_();
  const parts = raw.toString().split(",");
  const emails = [];

  parts.forEach(p => {
    let token = p.trim();
    if (!token) return;

    // If it already looks like an email, use as-is
    if (token.indexOf("@") !== -1) {
      emails.push(token);
      return;
    }

    // Otherwise treat as nickname and look up in user master
    const email = nicknameMap[token];
    if (email) {
      emails.push(email);
    } else {
      // Unknown nickname: skip or log — do NOT guess
      Logger.log(`No email found for nickname: ${token}`);
    }
  });

  return emails;
}

